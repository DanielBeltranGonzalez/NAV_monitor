# Puerto del host donde se expone la app (por defecto: 3000)
HOST_PORT=3000

# Ruta a la base de datos SQLite dentro del contenedor
DATABASE_URL=file:/data/nav.db

# Secreto para firmar los JWT (cambiar por un valor aleatorio seguro)
JWT_SECRET=cambiar-por-secreto-aleatorio-seguro

# Clave AES-256 para cifrado de la base de datos (generar con: openssl rand -hex 32)
# Si no se define, la BD queda sin cifrar (aceptable solo en desarrollo)
DB_ENCRYPTION_KEY=
